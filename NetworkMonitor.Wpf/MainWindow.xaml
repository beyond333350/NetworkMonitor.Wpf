<Window x:Class="NetworkMonitor.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetworkMonitor" Height="750" Width="1200"
        WindowState="Maximized"
        Background="{DynamicResource BrushBackground}" 
        Foreground="{DynamicResource BrushForeground}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushNavText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Effect" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" Margin="6,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BrushNavItemHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource BrushNavBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,30,0,10">
                    <TextBlock Text="NetworkMonitor" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Row="1" Margin="12,20,12,0">
                    <Button x:Name="BtnNavHome" Style="{StaticResource NavButtonStyle}" Content="🏠 主页" Margin="0,5" Height="50" FontSize="16" Click="BtnNavHome_Click"/>
                    <Button x:Name="BtnNavMonitor" Style="{StaticResource NavButtonStyle}" Content="📊 监控面板" Margin="0,5" Height="50" FontSize="16" Click="BtnNavMonitor_Click"/>
                    <Button x:Name="BtnNavTrace" Style="{StaticResource NavButtonStyle}" Content="📍 路由跟踪" Margin="0,5" Height="50" FontSize="16" Click="BtnNavTrace_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl x:Name="MainContent" Grid.Column="1" Margin="16"/>
    </Grid>
</Window>