<UserControl x:Class="NetworkMonitor.Wpf.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="5" Background="{DynamicResource BrushControlBackground}" CornerRadius="8" Padding="8" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
            <TextBox x:Name="TxtLogOutput" 
                     Background="Transparent" 
                     Foreground="{DynamicResource BrushForeground}" 
                     BorderThickness="0" 
                     FontSize="14" 
                     IsReadOnly="True" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto" 
                     Text=""/>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Vertical" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Margin="0,10,0,20">
                    <Button x:Name="BtnUploadTest" Content="上传带宽测试" Width="140" Height="40" Margin="0,0,10,0" Click="BtnUploadTest_Click"/>
                    <Button x:Name="BtnDownloadTest" Content="下载带宽测试" Width="140" Height="40" Click="BtnDownloadTest_Click"/>
                </StackPanel>

                <Border Margin="5" Background="{DynamicResource BrushBackground}" CornerRadius="6" Padding="5">
                    <TextBox x:Name="TxtTargetBandwidth" Text="50" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource BrushForeground}" VerticalAlignment="Center" FontSize="13"/>
                </Border>
                <TextBlock Text="请输入测试带宽(Mbps)" FontSize="10" Foreground="#666" Margin="10,0,0,15"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button x:Name="BtnUploadLoss" Content="上传丢包测试" Width="140" Height="40" Margin="0,0,10,0" Click="BtnUploadLoss_Click"/>
                    <Button x:Name="BtnDownloadLoss" Content="下载丢包测试" Width="140" Height="40" Click="BtnDownloadLoss_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button x:Name="BtnSpeedTest" Content="SPEEDTEST测速" Width="140" Height="40" Margin="0,0,10,0" Click="BtnSpeedTest_Click"/>
                    <Button x:Name="BtnUstcTest" Content="中科大测速" Width="140" Height="40" Click="BtnUstcTest_Click"/>
                </StackPanel>

                <Border Margin="5" Background="{DynamicResource BrushBackground}" CornerRadius="6" Padding="5">
                    <ComboBox x:Name="CmbIpList" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource BrushForeground}" VerticalAlignment="Center" FontSize="13" IsEditable="True"/>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,20">
                    <Button x:Name="BtnPing" Content="PING" Width="140" Height="40" Margin="0,0,10,0" Click="BtnPing_Click"/>
                    <Button x:Name="BtnTcping" Content="TCPING" Width="140" Height="40" Click="BtnTcping_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button x:Name="BtnSysInfo" Content="获取本机系统硬件信息" Width="290" Height="40" Click="BtnSysInfo_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button x:Name="BtnClearLog" Content="清空所有日志内容" Width="290" Height="40" Click="BtnClearLog_Click"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Vertical" VerticalAlignment="Bottom" Margin="0,0,0,5">
                <TextBlock Text="服务器地址" Foreground="Gray" Margin="5,0,0,0"/>
                <Border Margin="5" Background="{DynamicResource BrushBackground}" CornerRadius="6" Padding="5">
                    <ComboBox x:Name="CmbServerAddr" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource BrushForeground}" VerticalAlignment="Center" FontSize="13" IsEditable="True"/>
                </Border>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>