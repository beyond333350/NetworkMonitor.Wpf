<UserControl x:Class="NetworkMonitor.Wpf.TraceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BrushControlBackground}" CornerRadius="8" Padding="20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📍 广域网路由跟踪 (Traceroute)" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource BrushForeground}" Margin="0,0,30,0"/>

                <TextBlock Text="目标地址/域名:" Foreground="Gray" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <Border Background="{DynamicResource BrushBackground}" CornerRadius="6" Padding="5" Width="300" Margin="0,0,15,0">
                    <ComboBox x:Name="CmbTraceIp" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource BrushForeground}" VerticalAlignment="Center" FontSize="15" IsEditable="True"/>
                </Border>

                <Button x:Name="BtnStartTrace" Content="开始跟踪" Width="140" Height="40" FontSize="16" Click="BtnStartTrace_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource BrushControlBackground}" CornerRadius="8" Padding="15">
            <TextBox x:Name="TxtTraceOutput" 
                     Background="Transparent" 
                     Foreground="{DynamicResource BrushForeground}" 
                     BorderThickness="0" 
                     FontSize="14" 
                     IsReadOnly="True" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto" 
                     Text="等待发起路由跟踪...&#x0a;"/>
        </Border>
    </Grid>
</UserControl>